{
  "name": "react-rsc-commerce-stylex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "node scripts/clean.mjs && NODE_ENV=production BUNDLER_MODE=production bundler build --config bundler.config.mjs",
    "start": "BUNDLER_COMMERCE_SERVER_LIBRARY=1 NODE_ENV=production node --import @bundler/assets/register --require @bundler/react-rsc-plugin/register-source-maps scripts/start.mjs",
    "prod": "node scripts/clean.mjs && NODE_ENV=production BUNDLER_MODE=production bundler build --config bundler.config.mjs && BUNDLER_COMMERCE_SERVER_LIBRARY=1 NODE_ENV=production node --import @bundler/assets/register --require @bundler/react-rsc-plugin/register-source-maps scripts/start.mjs",
    "dev": "BUNDLER_COMMERCE_SERVER_LIBRARY=1 NODE_ENV=development BUNDLER_MODE=development node --import @bundler/assets/register --require @bundler/react-rsc-plugin/register-source-maps scripts/dev.mjs"
  },
  "dependencies": {
    "@bundler/assets": "workspace:*",
    "@bundler/browser-package-resolver": "workspace:*",
    "@bundler/bundler": "workspace:*",
    "@bundler/cjs-to-esm": "workspace:*",
    "@bundler/node-package-resolver": "workspace:*",
    "@bundler/react-rsc-plugin": "workspace:*",
    "@bundler/react-server-dom": "workspace:*",
    "@bundler/rsc-example-server": "workspace:*",
    "@bundler/stylex-plugin": "workspace:*",
    "@stylexjs/stylex": "0.19.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  }
}
