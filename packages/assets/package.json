{
  "name": "@bundler/assets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node-loader": "./node-loader.mjs",
    "./register": "./register.mjs",
    "./runtime": "./runtime.mjs",
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@bundler/shared": "workspace:*"
  }
}
