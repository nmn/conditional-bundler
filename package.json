{
  "name": "conditional-bundler",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "corepack pnpm -r build",
    "clean": "corepack pnpm -r clean",
    "clean:example-caches": "node scripts/clean-example-caches.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "corepack pnpm -r build && NODE_OPTIONS=--experimental-vm-modules corepack pnpm exec jest --runInBand",
    "test:hmr": "node scripts/test-example-hmr.mjs",
    "test:hmr:install": "playwright install chromium"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jridgewell/trace-mapping": "^0.3.31",
    "@stylexjs/stylex": "0.19.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.56.1"
  }
}
